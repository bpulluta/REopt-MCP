# REopt MCP — Environment Variables
#
# Copy to .env and fill in your API key:
#   cp .env.example .env
#
# Get a free API key at https://developer.nlr.gov/signup/

#NLR_API_KEY=your_api_key_here

# REopt API base URL (default: production /stable endpoint)
# REOPT_API_BASE_URL=https://developer.nlr.gov/api/reopt/stable

# URDB rate search (searchUrdbRates tool). URDB accepts the same NLR developer key,
# so OPENEI_API_KEY is optional and falls back to NLR_API_KEY.
# OPENEI_API_KEY=your_api_key_here
# URDB_API_BASE_URL=https://api.openei.org/utility_rates

# TLS behind a corporate inspection proxy (Netskope/Zscaler, etc.)
# ----------------------------------------------------------------
# Symptom: fetch fails with "self-signed certificate in certificate chain"
# even though `curl` to the same URL works. The proxy re-signs HTTPS with a
# private CA that lives in your OS trust store but not in Node's bundled store.
#
# Preferred (secure) fix — tell Node to read the OS trust store. Requires
# Node >= 22.15. Add to .mcp.json so the server launches with it:
#   "env": { "NODE_OPTIONS": "--use-system-ca" }
#
# Escape hatch (insecure) — skip TLS verification entirely. Use only on a
# trusted network; disables verification for ALL outbound requests.
# REOPT_TLS_INSECURE=1