# ==============================================================================
# .env.example - Environment Variables for Local Development
# ==============================================================================
#
# IMPORTANT: This file is ONLY needed for local development and testing.
# 
# For using the MCP server with GitHub Copilot Chat:
#   → Configure your API key in the MCP user configuration (see README.md)
#   → Do NOT use this .env file
#
# For local testing (running tests/simple_test.py):
#   1. Copy this file: cp .env.example .env
#   2. Add your API key below
#   3. Run: pixi run python tests/simple_test.py
#
# ==============================================================================

# Get your API key from https://developer.nrel.gov/signup/
NREL_API_KEY=your_api_key_here

# REopt API base URL (default is production, /stable is equivalent to /v3)
REOPT_API_BASE_URL=https://developer.nrel.gov/api/reopt/stable
